---
import { ImagesIndex } from "../../assets/ImagesIndex";
//const bg = ImagesIndex.IMG_8077;
const bg = ImagesIndex.IMG_9063;
---
<section class="section-frame hero-section" style={`background:linear-gradient(#00000044),url(${bg}); background-position:center; background-size:cover;`}>
    <p class="text-xl hero-section__concept">夜が明けるたび、少しずつ。</p>
    <img src={ImagesIndex.dawn_logo} class="hero-section__logo" />
</section>

<style lang="scss">
.hero-section{
    position:relative;
    display:flex;
    justify-content:center;
    align-items:center;
    background-position: center;
    background-size: cover;

    &__concept{
        letter-spacing: 0.5rem;
    }
    &__logo{
        position:absolute;
        bottom:0;
        right:0;
        width:30rem;
    }

}
</style>